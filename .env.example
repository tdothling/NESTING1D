# GEMINI_API_KEY: Required for Gemini AI API calls (SERVER-SIDE ONLY).
# NEVER use NEXT_PUBLIC_ prefix — that exposes the key in the browser.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# APP_URL: The URL where this applet is hosted.
APP_URL="http://localhost:3000"

# SUPABASE: These are safe as NEXT_PUBLIC_ because Supabase
# relies on Row-Level Security (RLS) for protection, not key secrecy.
NEXT_PUBLIC_SUPABASE_URL="YOUR_SUPABASE_URL_HERE"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY_HERE"
